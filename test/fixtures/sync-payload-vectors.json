{
  "_comment": "M6-B3A §3 shared drift fixture. Each vector is run through the Rust change_contract_violation AND the TS changeContractViolation; both MUST return the same verdict (expect=null → accepted, else the exact stable code). Deliberately small ASCII so the client's char-length and the server's byte-length payload bound never diverge. SYNC_PAYLOAD_TOO_LARGE is intentionally NOT here (it is the one check where char vs byte length can differ near the 32 MB limit).",
  "vectors": [
    { "table": "products", "action": "insert", "data": "{\"id\":\"p1\",\"brand\":\"Rolex\",\"name\":\"Sub\"}", "expect": null },
    { "table": "products", "action": "update", "data": "{\"sku\":\"X-1\",\"images\":\"[\\\"a\\\",\\\"b\\\"]\"}", "expect": null },
    { "table": "invoices", "action": "update", "data": "{\"id\":\"i1\",\"gross_amount\":\"100\"}", "expect": null },
    { "table": "invoices", "action": "delete", "data": "{}", "expect": null },
    { "table": "products", "action": "delete", "data": "", "expect": null },
    { "table": "ledger_entries", "action": "insert", "data": "{\"id\":\"l1\",\"account\":\"CASH\",\"amount\":\"5\"}", "expect": null },
    { "table": "products", "action": "update", "data": "{\"bad_field\":1}", "expect": "SYNC_FIELD_NOT_ALLOWED" },
    { "table": "products", "action": "update", "data": "{\"id\":\"p1\",\"nope\":2}", "expect": "SYNC_FIELD_NOT_ALLOWED" },
    { "table": "products", "action": "update", "data": "{\"BadColumn\":1}", "expect": "SYNC_COLUMN_NAME_INVALID" },
    { "table": "products", "action": "update", "data": "{\"bad field\":1}", "expect": "SYNC_COLUMN_NAME_INVALID" },
    { "table": "products", "action": "update", "data": "[1,2,3]", "expect": "SYNC_PAYLOAD_INVALID" },
    { "table": "products", "action": "update", "data": "\"just a string\"", "expect": "SYNC_PAYLOAD_INVALID" },
    { "table": "products", "action": "update", "data": "not valid json", "expect": "SYNC_PAYLOAD_INVALID" },
    { "table": "products", "action": "update", "data": "{\"brand\":\"a\",\"brand\":\"b\"}", "expect": "SYNC_PAYLOAD_DUPLICATE_KEY" },
    { "table": "products", "action": "update", "data": "{\"brand\":\"a\",\"\\u0062rand\":\"b\"}", "expect": "SYNC_PAYLOAD_DUPLICATE_KEY" },
    { "table": "products", "action": "drop", "data": "{}", "expect": "SYNC_OPERATION_NOT_ALLOWED" },
    { "table": "purchase_inbox", "action": "update", "data": "{\"id\":\"pi1\",\"status\":\"done\"}", "expect": null },
    { "table": "purchase_inbox", "action": "insert", "data": "{\"id\":\"pi1\",\"images\":\"[]\",\"status\":\"pending\"}", "expect": null },
    { "table": "purchase_inbox", "action": "delete", "data": "{}", "expect": "SYNC_OPERATION_NOT_ALLOWED" },
    { "table": "ledger_entries", "action": "delete", "data": "{}", "expect": "SYNC_OPERATION_NOT_ALLOWED" },
    { "table": "ledger_entries", "action": "update", "data": "{\"id\":\"l1\"}", "expect": "SYNC_OPERATION_NOT_ALLOWED" },
    { "table": "invoice_lines", "action": "update", "data": "{\"id\":\"il1\"}", "expect": "SYNC_OPERATION_NOT_ALLOWED" },
    { "table": "invoice_lines", "action": "delete", "data": "{}", "expect": null },
    { "table": "users", "action": "update", "data": "{}", "expect": "SYNC_CONTROL_PLANE_TABLE_FORBIDDEN" },
    { "table": "enrolled_devices", "action": "update", "data": "{}", "expect": "SYNC_CONTROL_PLANE_TABLE_FORBIDDEN" },
    { "table": "sync_changelog", "action": "update", "data": "{}", "expect": "SYNC_CONTROL_PLANE_TABLE_FORBIDDEN" },
    { "table": "sync_change_quarantine", "action": "update", "data": "{}", "expect": "SYNC_CONTROL_PLANE_TABLE_FORBIDDEN" },
    { "table": "Products", "action": "update", "data": "{}", "expect": "SYNC_TABLE_NAME_INVALID" },
    { "table": "products;drop", "action": "update", "data": "{}", "expect": "SYNC_TABLE_NAME_INVALID" },
    { "table": "some_unknown_table", "action": "update", "data": "{}", "expect": "SYNC_TABLE_NOT_ALLOWED" },
    { "table": "tenants", "action": "update", "data": "{}", "expect": "SYNC_TABLE_NOT_ALLOWED" },
    { "table": "categories", "action": "insert", "data": "{\"id\":\"c1\"}", "expect": "SYNC_TABLE_NOT_ALLOWED" }
  ]
}
