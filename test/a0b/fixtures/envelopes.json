{
  "group": "envelopes",
  "maxEnvelopeBytes": 1048576,
  "maxEnvelopeBytesName": "MAX_ENVELOPE_BYTES_V4",
  "u32Max": 4294967295,
  "operationTypePattern": "^[A-Z][A-Z0-9_]{2,63}$",
  "schema": {
    "OperationEnvelope": [
      "operationId:uuid",
      "serverSequence:i64-string>=1",
      "operationType:string",
      "branchId:string",
      "mutationCount:u32-integer",
      "mutations:MaterializedMutation[]",
      "result:object"
    ],
    "MaterializedMutation": [
      "ordinal:u32-integer(0-based,dense,canonical-position)",
      "table:string",
      "op:insert|update",
      "recordId:string",
      "payload:object"
    ],
    "mutationOrder": "sort by UTF-8 bytes of canonical-json([table, recordId]); ordinal = position"
  },
  "u32Validity": [
    {
      "name": "zero",
      "value": 0,
      "expect": "valid"
    },
    {
      "name": "one",
      "value": 1,
      "expect": "valid"
    },
    {
      "name": "u32-max",
      "value": 4294967295,
      "expect": "valid"
    },
    {
      "name": "string",
      "value": "1",
      "expect": "EXPECTED_U32_INTEGER"
    },
    {
      "name": "negative",
      "value": -1,
      "expect": "U32_NEGATIVE"
    },
    {
      "name": "float",
      "value": 1.5,
      "expect": "U32_NOT_INTEGER"
    },
    {
      "name": "overflow",
      "value": 4294967296,
      "expect": "U32_OUT_OF_RANGE"
    }
  ],
